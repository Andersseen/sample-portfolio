---
import MainLayout from '@/layouts/MainLayout.astro';
import LavaLamp from '@/components/LavaLamp/LavaLamp';
import Skills from '@/components/skills';
import Contact from '@/components/contact';
import WaveDivider from '@/components/WaveDivider/WaveDivider.astro';
import About from '@/components/About/About';
import { CONTENT } from '@/data/content';
import '@/components/Hero/Hero.scss';
---

<MainLayout title="Portfolio">
  <section class="hero">
    <LavaLamp client:load />
    <div class="hero__content">
      <h1 class="hero__title">{CONTENT.hero.title}</h1>
      <p class="hero__subtitle">{CONTENT.hero.subtitle}</p>
    </div>
  </section>

  <div class="relative">
    <div class="section-stage section-stage--about top-0">
      <WaveDivider />
      <About client:only="react" />
    </div>
    <div class="section-stage top-0">
      <Skills client:only="react" />
    </div>
    <div class="section-stage top-0">
      <Contact client:load />
    </div>
  </div>
</MainLayout>

<style lang="scss">
  .relative {
    position: relative;
  }

  .section-stage {
    position: sticky;
    top: 0;
  }

  .section-stage--about {
    height: 100dvh;
    position: sticky;
    top: 0;
    overflow: hidden;
    background: var(--color-background);
  }

  .section-stage--about :global(.wave-divider) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 5;
    pointer-events: none;
  }

  .section-stage--about :global(.about) {
    height: 100%;
    min-height: 100%;
  }

  .top-0 {
    top: 0;
  }
</style>