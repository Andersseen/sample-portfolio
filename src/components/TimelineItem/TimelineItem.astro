---
import './TimelineItem.scss';

interface Props {
  year: string;
  title: string;
  description: string;
}

const { year, title, description } = Astro.props;
---

<div class="timeline-item">
  <div class="timeline-item__year">{year}</div>
  <div class="timeline-item__header">
    <h3 class="timeline-item__title">{title}</h3>
  </div>
  <div class="timeline-item__description">{description}</div>
</div>